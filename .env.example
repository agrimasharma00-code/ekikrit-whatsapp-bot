# ⚠️ NEVER PUSH THIS FILE TO GIT!
# This is for LOCAL DEVELOPMENT ONLY
# Copy this to .env and fill in your actual credentials

# Twilio Credentials
# Get from: https://console.twilio.com
TWILIO_SID=your_account_sid_here
TWILIO_TOKEN=your_auth_token_here
TWILIO_WHATSAPP=whatsapp:+14155238886

# Local Development (ngrok)
# Get from running: ngrok http 8000
YOUR_NGROK_URL=https://xxxx-xxxx-xxxx.ngrok-free.dev

# Production (deployed app URL)
# Replace with your Heroku/Railway/Render URL when deploying
# YOUR_NGROK_URL=https://your-ekikrit-app.herokuapp.com
